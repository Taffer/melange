{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://chainguard.dev/melange-schema.json",
    "title": "melanage",
    "description": "melange build file schema",
    "type": "object",
    "properties": {
        "data": {
            "description": "Data used during the build",
            "type": "object"
        },
        "environment": {
            "description": "Build environment",
            "type": "object"
        },
        "package": {
            "description": "Package definition",
            "type": "object"
        },
        "pipeline": {
            "description": "Build/test pipeline",
            "type": "object"
        },
        "subpackages": {
            "description": "Sub-package definitions",
            "type": "object"
        },
        "test": {
            "description": "Test definitions",
            "type": "object"
        },
        "update": {
            "description": "Update check definition",
            "type": "object"
        },
        "vars": {
            "description": "Variables used during the build",
            "type": "object"
        },
        "var-transforms": {
            "description": "Variable transformations",
            "type": "object"
        }
    }
}
